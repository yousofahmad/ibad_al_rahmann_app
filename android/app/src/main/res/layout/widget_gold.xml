<?xml version="1.0" encoding="utf-8"?>
<!-- Golden Premium Widget (4×2): Minimalist Luxury Design -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl">

    <!-- 1. Background Image -->
    <ImageView
        android:id="@+id/widget_gold_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_bg_gold"
        android:translationY="-20dp" />

    <!-- 2. Dark Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- 3. Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layoutDirection="rtl"
        android:gravity="center"
        android:padding="16dp">

        <!-- Top Section: Header Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layoutDirection="rtl"
            android:gravity="center_vertical"
            android:padding="4dp">

            <!-- Right (RTL Start): City & Hijri -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:gravity="start">

                <TextView
                    android:id="@+id/tv_gold_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="القاهرة"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textDirection="locale" />

                <TextView
                    android:id="@+id/tv_gold_hijri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="١ رمضان ١٤٤٧"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:textDirection="locale" />
            </LinearLayout>

            <!-- Left (RTL End): Next Prayer & Timer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_gold_next_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="العصر متبقي"
                    android:textColor="@color/widget_accent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:textDirection="locale" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal"
                    android:layoutDirection="ltr"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_gold_timer_sign"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="–"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textDirection="ltr" />

                    <Chronometer
                        android:id="@+id/tv_gold_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textDirection="ltr" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#33FFFFFF" />

        <!-- Bottom Section: 5 Prayers Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="rtl"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingHorizontal="4dp"
            android:weightSum="5">

            <!-- Fajr -->
            <LinearLayout
                android:id="@+id/box_fajr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView
                    android:id="@+id/tv_fajr_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="فجر"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center" />
                <TextView
                    android:id="@+id/tv_fajr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="05:12"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center"
                    android:textDirection="ltr" />
            </LinearLayout>

            <!-- Dhuhr -->
            <LinearLayout
                android:id="@+id/box_dhuhr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView
                    android:id="@+id/tv_dhuhr_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ظهر"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center" />
                <TextView
                    android:id="@+id/tv_dhuhr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="12:05"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center"
                    android:textDirection="ltr" />
            </LinearLayout>

            <!-- Asr -->
            <LinearLayout
                android:id="@+id/box_asr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView
                    android:id="@+id/tv_asr_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عصر"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center" />
                <TextView
                    android:id="@+id/tv_asr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="03:32"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center"
                    android:textDirection="ltr" />
            </LinearLayout>

            <!-- Maghrib -->
            <LinearLayout
                android:id="@+id/box_maghrib"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView
                    android:id="@+id/tv_maghrib_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مغرب"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center" />
                <TextView
                    android:id="@+id/tv_maghrib_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="06:21"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center"
                    android:textDirection="ltr" />
            </LinearLayout>

            <!-- Isha -->
            <LinearLayout
                android:id="@+id/box_isha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView
                    android:id="@+id/tv_isha_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عشاء"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center" />
                <TextView
                    android:id="@+id/tv_isha_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="07:45"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textAlignment="center"
                    android:textDirection="ltr" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
