<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_gold"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:weightSum="100">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="42" 
        android:paddingHorizontal="24dp"
        android:paddingBottom="0dp"
        android:paddingTop="20dp" 
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/tv_large_status_prefix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="4dp"
            android:text="متبقي على الفجر"
            android:textColor="#3B2A00" 
            android:textSize="26sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/tv_large_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="4dp"
            android:textColor="#3B2A00" 
            android:textSize="24sp"
            android:textStyle="bold"
            android:textDirection="ltr" />
    </RelativeLayout>


<LinearLayout
        android:id="@+id/prayers_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp" 
        android:paddingTop="34dp" 
        android:weightSum="5">

        <LinearLayout android:id="@+id/ll_large_fajr_container" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_marginTop="0dp" android:layout_marginBottom="0dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tv_large_fajr_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الفجر" android:textColor="#F2D675" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom" android:layoutDirection="ltr">
                <TextView android:id="@+id/tv_large_fajr_ampm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="2dp" android:layout_marginBottom="2dp" android:text="" android:textColor="#E0E0E0" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
                <TextView android:id="@+id/tv_large_fajr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textDirection="ltr" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:id="@+id/ll_large_dhuhr_container" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_marginTop="0dp" android:layout_marginBottom="0dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tv_large_dhuhr_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الظهر" android:textColor="#F2D675" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
             <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom" android:layoutDirection="ltr">
                <TextView android:id="@+id/tv_large_dhuhr_ampm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="2dp" android:layout_marginBottom="2dp" android:text="" android:textColor="#E0E0E0" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
                <TextView android:id="@+id/tv_large_dhuhr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textDirection="ltr" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:id="@+id/ll_large_asr_container" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_marginTop="0dp" android:layout_marginBottom="0dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tv_large_asr_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العصر" android:textColor="#F2D675" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
             <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom" android:layoutDirection="ltr">
                <TextView android:id="@+id/tv_large_asr_ampm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="2dp" android:layout_marginBottom="2dp" android:text="" android:textColor="#E0E0E0" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
                <TextView android:id="@+id/tv_large_asr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textDirection="ltr" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:id="@+id/ll_large_maghrib_container" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_marginTop="0dp" android:layout_marginBottom="0dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tv_large_maghrib_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المغرب" android:textColor="#F2D675" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
             <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom" android:layoutDirection="ltr">
                <TextView android:id="@+id/tv_large_maghrib_ampm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="2dp" android:layout_marginBottom="2dp" android:text="" android:textColor="#E0E0E0" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
                <TextView android:id="@+id/tv_large_maghrib_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textDirection="ltr" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:id="@+id/ll_large_isha_container" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:layout_marginTop="0dp" android:layout_marginBottom="0dp" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tv_large_isha_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العشاء" android:textColor="#F2D675" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
             <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom" android:layoutDirection="ltr">
                <TextView android:id="@+id/tv_large_isha_ampm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="2dp" android:layout_marginBottom="2dp" android:text="" android:textColor="#E0E0E0" android:textSize="14sp" android:textStyle="bold" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
                <TextView android:id="@+id/tv_large_isha_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textDirection="ltr" android:shadowColor="#4D000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
    
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="13"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:gravity="center_vertical">
        <TextView android:id="@+id/tv_large_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="١٥ رمضان ١٤٤٧" android:textColor="#3B2A00" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        <TextView android:id="@+id/tv_large_location" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:text="٤ مارس ٢٠٢٦" android:textColor="#3B2A00" android:textSize="14sp" android:textStyle="bold" android:textDirection="rtl" />
    </RelativeLayout>
</LinearLayout>