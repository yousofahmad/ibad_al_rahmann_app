<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_gold"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:weightSum="100">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="42" 
        android:paddingHorizontal="24dp"
        android:paddingBottom="0dp"
        android:paddingTop="20dp" 
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/tv_large_status_prefix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="4dp"
            android:text="متبقي على الفجر"
            android:textColor="#000000" 
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:layoutDirection="ltr"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/tv_large_status_sign"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#000000" 
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:textDirection="ltr" />

            <Chronometer
                android:id="@+id/tv_large_chronometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000" 
                android:textSize="24sp"
                android:textStyle="bold"
                android:textDirection="ltr" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/prayers_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="43"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp" 
        android:paddingTop="30dp" 
        android:weightSum="5">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tv_large_fajr_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الفجر" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_large_fajr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--:--" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tv_large_dhuhr_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الظهر" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_large_dhuhr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--:--" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tv_large_asr_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العصر" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_large_asr_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--:--" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tv_large_maghrib_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المغرب" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_large_maghrib_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--:--" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tv_large_isha_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="العشاء" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_large_isha_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--:--" android:textColor="#4A3B00" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="15"
        android:paddingHorizontal="24dp"
        android:gravity="center_vertical">
        <TextView android:id="@+id/tv_large_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="١٥ رمضان ١٤٤٧" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" android:textDirection="ltr" />
        <TextView android:id="@+id/tv_large_location" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:text="٤ مارس ٢٠٢٦" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" android:textDirection="rtl" />
    </RelativeLayout>
</LinearLayout>