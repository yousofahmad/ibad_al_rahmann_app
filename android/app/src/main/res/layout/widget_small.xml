<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_gold"
    android:gravity="center"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:padding="2dp"> 
    
    <TextView
        android:id="@+id/tv_widget_small_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الفجر"
        android:textColor="#4A3B00" 
        android:textSize="14sp" 
        android:textStyle="bold"
        android:gravity="center"
        android:singleLine="true"
        android:textAlignment="center"
        android:textDirection="locale" />

    <TextView
        android:id="@+id/tv_widget_small_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:text="05:30 ص"
        android:textColor="#1A1400" 
        android:textSize="18sp" 
        android:textStyle="bold"
        android:gravity="center"
        android:singleLine="true"
        android:textAlignment="center"
        android:textDirection="ltr"
        android:includeFontPadding="false" />

    <View
        android:layout_width="35dp" 
        android:layout_height="1.5dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_gravity="center"
        android:background="#4A3B00" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="المتبقي"
        android:textColor="#665300"
        android:textSize="10sp" 
        android:gravity="center"
        android:singleLine="true"
        android:textAlignment="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layoutDirection="ltr">
        
        <TextView
            android:id="@+id/tv_widget_small_status_sign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#4A3B00"
            android:textSize="14sp" 
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:textDirection="ltr" />

        <Chronometer
            android:id="@+id/tv_widget_small_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4A3B00"
            android:textSize="14sp" 
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            android:textDirection="ltr"
            android:countDown="true"
            android:includeFontPadding="false" />
    </LinearLayout>

</LinearLayout>