<?xml version="1.0" encoding="utf-8"?>
<!-- Small Widget (2×2): Next Prayer Card -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_gold"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:padding="16dp">

    <!-- Prayer Name -->
    <TextView
        android:id="@+id/tv_widget_small_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الفجر"
        android:textColor="@color/widget_accent"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_gravity="center"
        android:textAlignment="center"
        android:textDirection="locale"
        android:letterSpacing="0.05" />

    <!-- Prayer Time (large) -->
    <TextView
        android:id="@+id/tv_widget_small_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="05:30 ص"
        android:textColor="@color/widget_text_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_gravity="center"
        android:textAlignment="center"
        android:textDirection="ltr" />

    <!-- Thin Gold Divider -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center"
        android:background="@color/widget_accent" />

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="المتبقي"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:textAlignment="center" />

    <!-- Live Countdown -->
    <Chronometer
        android:id="@+id/tv_widget_small_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/widget_accent"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_gravity="center"
        android:textAlignment="center"
        android:textDirection="ltr"
        android:countDown="true" />

</LinearLayout>
