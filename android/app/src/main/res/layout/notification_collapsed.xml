<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layoutDirection="rtl"
    android:paddingHorizontal="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layoutDirection="rtl"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_next_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الفجر متبقي:"
            android:textColor="#D0A871"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_next_prayer_sign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text=""
            android:textColor="#D0A871"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/tv_next_prayer_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:countDown="true"
            android:textColor="#D0A871"
            android:textDirection="ltr"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_hijri_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="١ رمضان ١٤٤٧ هـ"
        android:textColor="?android:attr/textColorSecondary"
        android:textDirection="locale"
        android:textSize="14sp" />
</RelativeLayout>