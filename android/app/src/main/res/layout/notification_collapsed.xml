<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="64dp"
    android:background="@drawable/bg_notification_rounded"
    android:layoutDirection="rtl"
    android:paddingHorizontal="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="12dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:baselineAligned="false"
    android:weightSum="1">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:layoutDirection="rtl"
        android:orientation="horizontal"
        android:gravity="center_vertical|start">

        <TextView
            android:id="@+id/tv_next_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="متبقي على الفجر"
            android:textColor="#D0A871"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/tv_next_prayer_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:paddingBottom="4dp"
            android:countDown="true"
            android:textColor="#D0A871"
            android:textDirection="ltr"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_hijri_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:gravity="end"
        android:text="١ رمضان ١٤٤٧ هـ"
        android:textColor="#D0A871"
        android:textDirection="locale"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
